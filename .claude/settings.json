{
  "permissions": {
    "allow": [
      "Bash(*)",
      "PowerShell(*)",
      "WebSearch",
      "Skill(*)",
      "Agent(*)",
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/sensitive-guard.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-write-claude-md-guard.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/commit-guard.sh\""
          }
        ]
      }
    ],
    "Stop": []
  }
}
